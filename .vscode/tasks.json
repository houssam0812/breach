		{
			"label": "install postgresql",
			"type": "shell",
			"command": "brew install postgresql@16 2>&1 | tail -20",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "start postgres and create db",
			"type": "shell",
			"command": "brew services start postgresql@16 && sleep 3 && /opt/homebrew/opt/postgresql@16/bin/createdb breach 2>&1 || echo 'db may already exist'",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "create breach db",
			"type": "shell",
			"command": "/opt/homebrew/opt/postgresql@16/bin/createdb breach 2>&1 && echo 'created' || echo 'already exists or error'",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "prisma db push",
			"type": "shell",
			"command": "npm run db:push 2>&1",
