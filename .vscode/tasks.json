			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "brew services list",
			"type": "shell",
			"command": "brew services list 2>&1 | head -30",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "check mongodb",
			"type": "shell",
			"command": "mongosh --eval 'db.runCommand({ping:1})' 2>&1 | head -5",
